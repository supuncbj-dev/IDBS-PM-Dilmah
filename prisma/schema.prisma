generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String   @unique
  mobile    String?
  role      String   @default("PROJECT_USER")
  password  String
}

model Project {
  id        String   @id @default(cuid())
  name      String
  type      String   // RND or CAPEX
  status    String   @default("Active")
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  startDate   String
  endDate     String
  assignee    String?
  dependsOn   String?
  status      String   @default("NOT_STARTED")
  comment     String?
  completedAt String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp String
  user      String
  action    String
  details   String
  createdAt DateTime @default(now())
}
